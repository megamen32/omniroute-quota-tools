{
  "name": "omniroute-quota-tools",
  "displayName": "OmniRoute Quota Tools",
  "description": "CLI for Claude Code and VS Code sidebar for OmniRoute provider quota usage.",
  "version": "0.2.1",
  "license": "MIT",
  "type": "commonjs",
  "private": false,
  "main": "./dist/extension.js",
  "bin": {
    "omniroute-quota": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "media"
  ],
  "scripts": {
    "build": "tsc -p .",
    "check": "tsc -p . --noEmit",
    "watch": "tsc -watch -p .",
    "package:vsix": "vsce package --no-dependencies",
    "cli": "node ./dist/cli.js"
  },
  "engines": {
    "node": ">=20",
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onView:omnirouteQuota.providers",
    "onCommand:omnirouteQuota.refresh",
    "onCommand:omnirouteQuota.setToken",
    "onCommand:omnirouteQuota.forceRefresh",
    "onCommand:omnirouteQuota.togglePercentMode"
  ],
  "categories": [
    "Other"
  ],
  "keywords": [
    "omniroute",
    "quota",
    "claude-code",
    "providers",
    "usage"
  ],
  "contributes": {
    "configuration": {
      "title": "OmniRoute Quota",
      "properties": {
        "omnirouteQuota.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:20128",
          "description": "OmniRoute dashboard/API base URL. Example: https://omniroute.example.com"
        },
        "omnirouteQuota.apiKey": {
          "type": "string",
          "default": "",
          "description": "Optional OmniRoute API key/access token with manage scope. Prefer the 'OmniRoute Quota: Set API Token' command, because VS Code settings can be synced/plain text."
        },
        "omnirouteQuota.authHeader": {
          "type": "string",
          "enum": [
            "authorization",
            "x-api-key",
            "x-omniroute-cli-token"
          ],
          "default": "authorization",
          "description": "Header used for the token. 'authorization' sends Bearer <token>; 'x-api-key' and 'x-omniroute-cli-token' send the raw token."
        },
        "omnirouteQuota.hiddenProviders": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Provider slugs to hide from the sidebar, for example: ['codex', 'github']."
        },
        "omnirouteQuota.autoRefreshIntervalSeconds": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Optional automatic sidebar refresh interval. 0 disables auto refresh."
        },
        "omnirouteQuota.showOnlyQuotaProviders": {
          "type": "boolean",
          "default": true,
          "description": "Hide active providers that have no cached quota data."
        },
        "omnirouteQuota.percentMode": {
          "type": "string",
          "enum": [
            "free",
            "used"
          ],
          "default": "free",
          "description": "Whether compact bars show quota remaining ('free') or inverted quota usage ('used')."
        },
        "omnirouteQuota.criticalThresholdPercent": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "maximum": 100,
          "description": "Remaining quota percentage at or below which sidebar items are marked red/critical."
        }
      }
    },
    "commands": [
      {
        "command": "omnirouteQuota.refresh",
        "title": "OmniRoute Quota: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "omnirouteQuota.forceRefresh",
        "title": "OmniRoute Quota: Refresh from Providers",
        "icon": "$(sync)"
      },
      {
        "command": "omnirouteQuota.togglePercentMode",
        "title": "OmniRoute Quota: Toggle Free/Used",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "omnirouteQuota.setToken",
        "title": "OmniRoute Quota: Set API Token"
      },
      {
        "command": "omnirouteQuota.clearToken",
        "title": "OmniRoute Quota: Clear Stored API Token"
      },
      {
        "command": "omnirouteQuota.clearHiddenProviders",
        "title": "OmniRoute Quota: Show All Providers"
      },
      {
        "command": "omnirouteQuota.openSettings",
        "title": "OmniRoute Quota: Open Settings",
        "icon": "$(settings-gear)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "omnirouteQuota",
          "title": "OmniRoute Quota",
          "icon": "media/quota.svg"
        }
      ]
    },
    "views": {
      "omnirouteQuota": [
        {
          "id": "omnirouteQuota.providers",
          "name": "Provider Quotas",
          "type": "webview",
          "icon": "media/quota-view.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "omnirouteQuota.refresh",
          "when": "view == omnirouteQuota.providers",
          "group": "navigation"
        },
        {
          "command": "omnirouteQuota.forceRefresh",
          "when": "view == omnirouteQuota.providers",
          "group": "navigation"
        },
        {
          "command": "omnirouteQuota.togglePercentMode",
          "when": "view == omnirouteQuota.providers",
          "group": "navigation"
        },
        {
          "command": "omnirouteQuota.openSettings",
          "when": "view == omnirouteQuota.providers",
          "group": "navigation"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/megamen32/omniroute-quota-tools.git"
  },
  "bugs": {
    "url": "https://github.com/megamen32/omniroute-quota-tools/issues"
  },
  "homepage": "https://github.com/megamen32/omniroute-quota-tools#readme"
}
